# =============================================================================
# find-unified 统一环境变量
# =============================================================================

# ── 通用 ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── 数据库 ────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:1234@localhost:5432/find_unified"

# ── Redis（BullMQ 任务队列）─────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── Anthropic API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_AUTH_TOKEN=   # 兼容旧字段，与 ANTHROPIC_API_KEY 二选一
# ANTHROPIC_BASE_URL=     # 使用代理或私有部署时填写，例如 https://your-proxy.com

# ── 敏感字段加密密钥（32 字节 hex，用于加密数据源密码/token）─────────────────
# 不填则使用内置开发密钥（仅限开发环境）
# 生产环境必须设置：openssl rand -hex 32
# ENCRYPTION_KEY=your-32-byte-hex-key

# ── apps/api ──────────────────────────────────────────────────────────────────
API_PORT=3001
FIND_CORE_URL=http://127.0.0.1:8787
SYNC_GIT_DIR=/tmp/find-sync/git
SYNC_HTTP_DIR=/tmp/find-sync/http
# FIND_CONFIG_PATH=/absolute/path/to/sources.json
# INGEST_TOKEN=your-ingest-token

# ── apps/web ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── services/find-core ────────────────────────────────────────────────────────
FIND_CORE_PORT=8787

# ── services/mcp-mock ────────────────────────────────────────────────────────
MCP_PORT=9090
